{
  "id": "qm-notification-response",
  "system": "QM",
  "method": "POST",
  "path": "/qm/notifications/:notificationId/responses",
  "summary": "Submit supplier root cause and corrective action",
  "requestSchema": {
    "type": "object",
    "required": ["rootCause", "correctiveAction", "owner"],
    "properties": {
      "rootCause": { "type": "string" },
      "correctiveAction": { "type": "string" },
      "owner": { "type": "string" }
    }
  },
  "responseSchema": {
    "type": "object",
    "required": ["notificationId", "status", "bapiReturn"],
    "properties": {
      "notificationId": { "type": "string" },
      "status": { "type": "string" },
      "bapiReturn": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["type", "message"],
          "properties": {
            "type": { "type": "string" },
            "id": { "type": "string" },
            "number": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    }
  }
}

