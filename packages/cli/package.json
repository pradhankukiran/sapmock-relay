{
  "name": "@sapmock/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "sapmock": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude dist/**"
  },
  "dependencies": {
    "@sapmock/api": "workspace:*",
    "@sapmock/core": "workspace:*",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "vitest": "^4.0.14"
  }
}
